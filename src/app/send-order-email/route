import { NextResponse } from 'next/server'
import nodemailer from 'nodemailer'

export async function POST(req: Request) {
  try {
    const { orderId, paymentId, items, total, shipping } = await req.json()

    if (!orderId || !items || !total || !shipping) {
      return NextResponse.json({ error: 'Missing required fields' }, { status: 400 })
    }

    const emailUser = process.env.EMAIL_USER
    const emailPass = process.env.EMAIL_APP_PASSWORD

    if (!emailUser || !emailPass) {
      console.error('Email credentials not configured')
      return NextResponse.json({ error: 'Email service not configured' }, { status: 500 })
    }

    const transporter = nodemailer.createTransport({
      service: 'gmail',
      auth: { user: emailUser, pass: emailPass },
    })

    // Build HTML for admin email
    const itemsList = items.map((item: any) => `
      <tr>
        <td style="padding:8px; border-bottom:1px solid #eee;">${item.name} (Size: ${item.size})</td>
        <td style="padding:8px; border-bottom:1px solid #eee; text-align:center;">${item.quantity}</td>
        <td style="padding:8px; border-bottom:1px solid #eee; text-align:right;">₹${(item.price * item.quantity).toLocaleString('en-IN')}</td>
      </table>
    `).join('')

    const adminHtml = `
      <div style="font-family: 'DM Sans', sans-serif; max-width: 600px; margin:0 auto; color:#2c1a0e;">
        <h2 style="color:#8b3a1e;">✨ New Order Received ✨</h2>
        <p><strong>Order ID:</strong> ${orderId}</p>
        <p><strong>Payment ID:</strong> ${paymentId}</p>
        <h3>Customer Details</h3>
        <p>
          <strong>Name:</strong> ${shipping.name}<br/>
          <strong>Email:</strong> ${shipping.email}<br/>
          <strong>Phone:</strong> ${shipping.phone}<br/>
          <strong>Address:</strong> ${shipping.address}, ${shipping.city} - ${shipping.pincode}
        </p>
        <h3>Order Summary</h3>
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr><th style="text-align:left; padding:8px; border-bottom:2px solid #8b3a1e;">Item</th>
              <th style="text-align:center; padding:8px; border-bottom:2px solid #8b3a1e;">Qty</th>
              <th style="text-align:right; padding:8px; border-bottom:2px solid #8b3a1e;">Amount</th>
            </tr>
          </thead>
          <tbody>${itemsList}</tbody>
          <tfoot>
            <tr>
              <td colspan="2" style="padding:12px 8px; text-align:right; font-weight:bold;">Total:</td>
              <td style="padding:12px 8px; text-align:right; font-weight:bold;">₹${total.toLocaleString('en-IN')}</td>
            </tr>
          </tfoot>
        </table>
        <p style="margin-top:24px; font-size:12px; color:#6b4c3b;">This order was placed through Seshara website. Please process shipping at the earliest.</p>
        <p style="margin-top:32px; font-style:italic;">— Seshara Team</p>
      </div>
    `

    // Send admin email
    await transporter.sendMail({
      from: `"Seshara Orders" <${emailUser}>`,
      to: emailUser, // Seshara.info@gmail.com
      subject: `🛍 New Order #${orderId} – ₹${total.toLocaleString('en-IN')}`,
      html: adminHtml,
    })

    // Send customer confirmation email
    const customerHtml = `
      <div style="font-family: 'DM Sans', sans-serif; max-width: 500px; color:#2c1a0e;">
        <h2>Thank you for shopping with Seshara! ♡</h2>
        <p>Your order <strong>#${orderId}</strong> has been received and will be shipped within 2‑3 business days.</p>
        <p><strong>Payment ID:</strong> ${paymentId}</p>
        <p>We'll keep you updated.</p>
        <p>— The Seshara Team</p>
      </div>
    `

    await transporter.sendMail({
      from: `"Seshara" <${emailUser}>`,
      to: shipping.email,
      subject: `Order Confirmation #${orderId} – Thank you ♡`,
      html: customerHtml,
    })

    return NextResponse.json({ success: true })
  } catch (error) {
    console.error('Email error:', error)
    return NextResponse.json({ error: 'Failed to send email' }, { status: 500 })
  }
}
